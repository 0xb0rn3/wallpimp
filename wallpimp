# ── DE / screen ───────────────────────────────────────────────────────────────
def detect_de():
    de=(os.environ.get("XDG_CURRENT_DESKTOP","")\
        or os.environ.get("DESKTOP_SESSION","")).lower()
    if "gnome" in de: return "gnome"
    if "xfce"  in de: return "xfce"
    return de or "unknown"

def screen_resolution():
    # Windows
    if _OS == "windows":
        try:
            import ctypes
            u = ctypes.windll.user32
            return u.GetSystemMetrics(0), u.GetSystemMetrics(1)
        except Exception: pass
    # macOS
    if _OS == "macos":
        try:
            out = subprocess.check_output(
                ["system_profiler","SPDisplaysDataType"],
                stderr=subprocess.DEVNULL, text=True)
            m = re.search(r"Resolution:\s*(\d+)\s*x\s*(\d+)", out)
            if m: return int(m.group(1)), int(m.group(2))
        except Exception: pass
        try:
            sc = 'tell application "Finder" to get bounds of window of desktop'
            out = subprocess.check_output(["osascript","-e",sc],
                                          stderr=subprocess.DEVNULL, text=True).strip()
            parts = out.split(",")
            if len(parts) == 4:
                return int(parts[2].strip()), int(parts[3].strip())
        except Exception: pass
    # Linux – xrandr / framebuffer / xdpyinfo
    try:
        out=subprocess.check_output(["xrandr","--current"],stderr=subprocess.DEVNULL,text=True)
        hits=re.findall(r"connected.*?(\d{3,5})x(\d{3,5})\+",out)
        if hits:
            best=max(hits,key=lambda m:int(m[0])*int(m[1]))
            return int(best[0]),int(best[1])
    except Exception: pass
    try:
        v=Path("/sys/class/graphics/fb0/virtual_size").read_text().strip()
        w,h=v.split(","); return int(w),int(h)
    except Exception: pass
    try:
        out=subprocess.check_output(["xdpyinfo"],stderr=subprocess.DEVNULL,text=True)
        m=re.search(r"dimensions:\s+(\d+)x(\d+)",out)
        if m: return int(m.group(1)),int(m.group(2))
    except Exception: pass
    return 1920,1080

