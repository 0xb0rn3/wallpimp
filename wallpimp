        print("  \u2500\u2500 Download Wallpapers \u2500\u2500\n")
        print(f"  Save to : {wdir}\n")
        print("  1. Download full library")
        print("  2. Download custom amount")
        print("  c. Change save directory")
        print("  0. Back\n")
        ch = input("  \u203a ").strip().lower()

        if ch == "0":
            break

        elif ch == "c":
            new = _prompt_change_dir(wdir)
            if new != wdir:
                wdir = new
                cfg["wallpaper_dir"] = str(wdir)
                save_config(cfg)

        elif ch in ("1", "2"):
            print_header()
            target = 0

            if ch == "2":
                # Custom amount — scan first so user knows the ceiling
                print("  \u2500\u2500 Custom Amount Download \u2500\u2500\n")
                print(f"  {_CYAN}Scanning sources \u2026{_RESET}", flush=True)
                ev = eng.rpc({"cmd": "scan"})
                avail = ev.get("total", 0)
                if avail:
                    print(f"  Available : {_GREEN}{avail:,}{_RESET} wallpapers\n")
                else:
                    print(f"  {_YLW}Could not determine exact count.{_RESET}\n")
                    avail = 999_999
                raw = input(f"  How many to download? [1-{avail:,}]: ").strip()
                try:
                    target = max(1, min(avail, int(raw)))
                except ValueError:
                    print("  Invalid number."); input("  Enter \u2026"); continue
            else:
                # Full library — skip scan, start immediately
                print("  \u2500\u2500 Full Library Download \u2500\u2500\n")
                if input("  Start? [y/N]: ").strip().lower() != "y":
                    continue

            bar_width   = 40
            spin_frames = ["\u280b","\u2819","\u2839","\u2838","\u283c",
                           "\u2834","\u2826","\u2827","\u2807","\u280f"]
            spin_idx    = [0]
            first_event = [True]

            def on_prog(ev):
                nonlocal first_event
                # Skip the engine's internal "resolving" status ping
                if ev.get("msg") == "resolving":
                    s = spin_frames[spin_idx[0] % len(spin_frames)]
                    spin_idx[0] += 1
                    print(f"\r  {_CYAN}{s}{_RESET} Resolving sources \u2026",
                          end="", flush=True)
                    return
                if first_event[0]:
                    # First real progress — clear the spinner line
                    print(f"\r{' ' * 50}\r", end="", flush=True)
                    first_event[0] = False
                n = ev.get("new", 0) + ev.get("dupes", 0)
                if target:
                    pct   = min(n / target, 1.0)
                    filled = int(bar_width * pct)
                    bar   = "\u2588" * filled + "\u2591" * (bar_width - filled)
                    print(f"\r  DOWNLOADING  {bar}  {n:,}/{target:,}", end="", flush=True)
                else:
                    # Indeterminate — rolling fill
                    pos   = n % bar_width
                    trail = 8
                    bar   = "".join(
                        "\u2588" if (pos - i) % bar_width < trail else "\u2591"
                        for i in range(bar_width)
                    )
                    print(f"\r  DOWNLOADING  {bar}  {n:,}", end="", flush=True)

            # Show spinner immediately while engine resolves branches
            print(f"  {_CYAN}\u280b{_RESET} Resolving sources \u2026", end="", flush=True)

            ev = eng.stream(
                {"cmd": "download",
                 "wdir": str(wdir),
                 "workers": int(cfg.get("download_workers", 8)),
                 "target": target},
                on_progress=on_prog,
            )
            print()  # newline after bar
            n = ev.get("new", 0)
            print(f"\n  {_GREEN}\u2713{_RESET} Done \u2014 {n:,} new wallpapers downloaded.")
            input("\n  Enter to continue \u2026")

