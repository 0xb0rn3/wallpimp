# ── Linux / systemd ───────────────────────────────────────────────────────────
_SVC_UNIT="""\
[Unit]
Description=WallPimp Slideshow
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart={exe} --daemon
EnvironmentFile={env_file}
Restart=on-failure
RestartSec=10

[Install]
WantedBy=graphical-session.target
"""

def _write_unit():
    _SVC_DIR.mkdir(parents=True,exist_ok=True)
    _SVC_FILE.write_text(_SVC_UNIT.format(exe=Path(sys.argv[0]).resolve(),env_file=_SESSION_ENV))
    subprocess.run(["systemctl","--user","daemon-reload"],capture_output=True)
    if _LEGACY_TIMER.exists():
        subprocess.run(["systemctl","--user","disable","--now","wallpimp-slideshow.timer"],capture_output=True)
        _LEGACY_TIMER.unlink(missing_ok=True)

def _svc(cmd):
    return subprocess.run(["systemctl","--user",cmd,"wallpimp-slideshow.service"],capture_output=True,text=True)

def _save_session_env():
    keys=["DISPLAY","WAYLAND_DISPLAY","DBUS_SESSION_BUS_ADDRESS","XDG_RUNTIME_DIR","XDG_CURRENT_DESKTOP","XDG_SESSION_TYPE"]
    lines=[f"{k}={os.environ[k]}" for k in keys if k in os.environ]
    _CFG_DIR.mkdir(parents=True,exist_ok=True)
    _SESSION_ENV.write_text("\n".join(lines)+"\n")
    if _OS != "windows": _SESSION_ENV.chmod(0o600)
    print(f"  {_GREEN}\u2713{_RESET} Session env saved to {_SESSION_ENV}")
    for l in lines: print(f"    {_DIM}{l}{_RESET}")

# ── macOS / launchd ──────────────────────────────────────────────────────────
_PLIST_CONTENT = """\
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.wallpimp.slideshow</string>
  <key>ProgramArguments</key><array>
    <string>{python}</string>
    <string>{script}</string>
    <string>--daemon</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardErrorPath</key>
  <string>{log}</string>
</dict></plist>
"""

def _plist_write():
    _PLIST_DIR.mkdir(parents=True, exist_ok=True)
    log = Path.home() / "Library" / "Logs" / "wallpimp-slideshow.log"
    content = _PLIST_CONTENT.format(
        python=sys.executable,
        script=str(Path(sys.argv[0]).resolve()),
        log=str(log),
    )
    _PLIST_FILE.write_text(content)

def _launchctl(verb):
    return subprocess.run(
        ["launchctl", verb, str(_PLIST_FILE)],
        capture_output=True, text=True)

# ── Windows / Task Scheduler ─────────────────────────────────────────────────
def _wintask(action):
    """create | delete | start | stop | query"""
    if action == "create":
        cmd = [
            "schtasks","/create","/f",
            "/tn", _WIN_TASK,
            "/tr", f'"{sys.executable}" "{Path(sys.argv[0]).resolve()}" --daemon',
            "/sc", "onlogon",
            "/rl", "limited",
        ]
    elif action == "delete":
        cmd = ["schtasks","/delete","/f","/tn",_WIN_TASK]
    elif action == "start":
        cmd = ["schtasks","/run","/tn",_WIN_TASK]
    elif action == "stop":
        cmd = ["taskkill","/f","/fi",f"WINDOWTITLE eq {_WIN_TASK}"]
    elif action == "query":
        cmd = ["schtasks","/query","/tn",_WIN_TASK,"/fo","list"]
    else:
        return None
    return subprocess.run(cmd, capture_output=True, text=True)

