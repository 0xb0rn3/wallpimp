def _sudo_mkdir(path):
    """Elevate via sudo (Linux/macOS) to create a root-owned directory."""
    print(f"  {_YLW}Directory requires elevated access:{_RESET} {path}")
    print(f"  Requesting privileges via sudo \u2026")
    try:
        r = subprocess.run(["sudo","mkdir","-p",str(path)])
        if r.returncode != 0: return False
        subprocess.run(["sudo","chown","-R",
                        f"{os.getuid()}:{os.getgid()}",str(path)])
        return True
    except FileNotFoundError:
        print(f"  {_RED}sudo not found.{_RESET} Run as root or change directory.")
        return False
    except Exception as e:
        print(f"  {_RED}sudo failed:{_RESET} {e}"); return False

def _win_mkdir(path):
    """On Windows prompt to run as Administrator or pick a different path."""
    print(f"  {_YLW}Permission denied:{_RESET} {path}")
    print(f"  On Windows, either:")
    print(f"    a) Run wallpimp as Administrator")
    print(f"    b) Choose a directory you own (e.g. C:\\Users\\you\\Pictures)")
    return False

def _ensure_dir(path):
    try:
        path.mkdir(parents=True, exist_ok=True); return True
    except PermissionError:
        if _OS == "windows": return _win_mkdir(path)
        return _sudo_mkdir(path)

