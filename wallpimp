def _stat_line(ev: dict, label: str) -> str:
    n = ev.get("new",   ev.get("New",   0))
    d = ev.get("dupes", ev.get("Dupes", 0))
    e = ev.get("errors",ev.get("Errors",0))
    err_s = f", {e} errors" if e else ""
    return (f"  {_GREEN}\u2713{_RESET} {label}: "
            f"{n} new, {d} dupes skipped{err_s}")

def _paginate(current: int):
    ans = input("  [n] next page  [q] stop: ").strip().lower()
