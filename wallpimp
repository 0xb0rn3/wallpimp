def spinner(label,fn,*args,**kwargs):
    frames=["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
    result=[None]; done=threading.Event(); err=[None]
    def target():
        try: result[0]=fn(*args,**kwargs)
        except Exception as e: err[0]=e
        finally: done.set()
    t=threading.Thread(target=target,daemon=True); t.start()
    i=0
    while not done.is_set():
        print(f"\r  {_CYAN}{frames[i%len(frames)]}{_RESET} {label}",end="",flush=True)
        time.sleep(0.08); i+=1
    print(f"\r  {_GREEN}\u2713{_RESET} {label}{'  ':5}")
    if err[0]: raise err[0]
    return result[0]

